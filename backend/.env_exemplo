# Database Configuration
# Rodando localmente (fora do Docker), use localhost
# Rodando via Docker, use o nome do serviço 'db'
DATABASE_URL_SG=mysql+mysqlconnector://cafe_user:cafe_password@localhost/cafe_db
DATABASE_URL_RJK=mysql+mysqlconnector://cafe_user:cafe_password@localhost/cafe_db
DATABASE_URL_CAFE=mysql+mysqlconnector://cafe_user:cafe_password@localhost/cafe_db

# Debug mode
DEBUG=true

# Photos storage path
FOTOS_PATH=/fotos
