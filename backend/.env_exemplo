# Database Configuration
# Rodando localmente (fora do Docker), use localhost
# Rodando via Docker, use o nome do serviço 'db'
DATABASE_URL_SG=mysql+mysqlconnector://cafe_user:cafe_password@localhost/cafe_db
DATABASE_URL_RJK=mysql+mysqlconnector://cafe_user:cafe_password@localhost/cafe_db
DATABASE_URL_CAFE=mysql+mysqlconnector://cafe_user:cafe_password@localhost/cafe_db

# Debug mode
DEBUG=true

# Photos storage path
FOTOS_PATH=/fotos

# Configurações de Origens Permitidas (CORS) - Separadas por vírgula
ALLOWED_ORIGINS=http://localhost:8090,http://192.168.1.10

# Configurações de IPs Permitidos - Separados por vírgula
# Se deixado em branco, todos os IPs serão aceitos.
ALLOWED_IPS=192.168.1.10,192.168.1.20

# Report Auth
REPORT_USER=admin
REPORT_PASSWORD=cafe123

